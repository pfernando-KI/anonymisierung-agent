# Optionale Umgebungsvariablen fuer den Anonymisierungs-Agenten.
# Diese Datei nach ".env" kopieren und Werte anpassen, falls noetig.
# Ohne .env gelten die Standardwerte aus config.py (localhost).

# Adresse des LM-Studio-Servers (Standard: http://localhost:1234/v1)
# Nur aendern, wenn LM Studio auf einem anderen Geraet oder Port laeuft.
LM_STUDIO_URL=http://localhost:1234/v1

# Modell-ID, exakt wie in LM Studio geladen
MODEL=google/gemma-4-e4b
